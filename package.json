{
  "name": "service-tracker",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "axios": "1.4.0",
    "dateformat": "5.0.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "4.9.0",
    "react-textarea-autosize": "8.4.1",
    "react-toastify": "9.1.3",
    "react-tooltip": "5.14.0",
    "react-transition-group": "4.4.5"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.27.1",
    "@tailwindcss/forms": "^0.5.11",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "bestzip": "^2.2.1",
    "ncp": "^2.0.0",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.3.2"
  },
  "scripts": {
    "dev": "vite serve --mode development",
    "build": "vite build --mode production && node move-css.js",
    "build:watch": "vite build --watch --mode development",
    "prepare:files": "./prepare-stable.sh",
    "zip": "cd ../ && bestzip service-tracker-olmc.zip service-tracker-olmc && rimraf service-tracker-olmc",
    "generate:stable": "npm run build && npm run prepare:files && npm run zip"
