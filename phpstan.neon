parameters:
    level: 8

    # Paths to analyze
    paths:
        - admin
        - includes

    # Exclude CLI classes that depend on WP-CLI (not available as stubs)
    excludePaths:
        - includes/CLI/*

    # WordPress integration
    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php

    # Generic object types
    universalObjectCratesClasses:
        - stdClass
        - WP_Error

    # Treat PHPDoc types as certain (more strict)
    treatPhpDocTypesAsCertain: true

# Use WordPress extension for better WP integration
includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
